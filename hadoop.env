CORE_CONF_fs_defaultFS=hdfs://namenode:8020
CORE_CONF_hadoop_http_staticuser_user=root
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false

# ======== OBSA 插件的配置 ========
# 开启 Hadoop 中的快照功能
HDFS_CONF_dfs_namenode_snapshot_allowed=true

# 以下为您需要补充的真实 OBS 认证信息
# 在容器中这会生成对应的 core-site.xml 配置项
CORE_CONF_fs_obs_access_key=YOUR_OBS_AK
CORE_CONF_fs_obs_secret_key=YOUR_OBS_SK
CORE_CONF_fs_obs_endpoint=obs.cn-internal-1.company.local
CORE_CONF_fs_obs_impl=org.apache.hadoop.fs.obs.OBSFileSystem
